POSTGRES_USER=servermanager
# Use a strong random password for production
POSTGRES_PASSWORD=
POSTGRES_DB=servermanager
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# Fernet encryption key for SSH private keys at rest (AES). BACK THIS UP — if lost, encrypted keys are unrecoverable.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# URL at which the API is reachable (for the "Add server" deploy script). With Nginx Proxy Manager at sshcontrol.com use https://sshcontrol.com (no port).
PUBLIC_API_URL=http://YOUR_SERVER_IP:8000

# When false (default in Docker), skip immediate SSH sync from backend to targets. Sync is still requested; target server's cron applies changes within ~1 min. Set true if backend can SSH to targets.
# ENABLE_SSH_SYNC=false

# --- SendGrid Email ---
# Required for signup email verification, password reset. Get API key from https://sendgrid.com
# SENDGRID_API_KEY=SG.xxxxx
# SENDGRID_FROM_EMAIL=noreply@sshcontrol.com
# SENDGRID_FROM_NAME=SSHCONTROL

# Frontend URL for email links (verify email, reset password)
# FRONTEND_URL=https://sshcontrol.com

# --- Frontend (Vite) - only when running "npm run dev" or Docker frontend ---
# Where the frontend proxies /api requests. Docker sets this automatically.
# - With Docker: PROXY_TARGET=http://backend:8000 (already in docker-compose)
# - Local dev (both on same PC): leave unset or PROXY_TARGET=http://localhost:8000
# PROXY_TARGET=http://localhost:8000

# HMR WebSocket (dev only). When using https://sshcontrol.com you must use secure WebSocket:
# VITE_HMR_HOST=sshcontrol.com
# VITE_HMR_SECURE=true
# (Docker Compose defaults these for production.) For local HTTP use: VITE_HMR_SECURE=false

# Access: https://sshcontrol.com (production) or localhost / LAN IP for dev.
# Ensure backend is running (port 8000) and frontend proxy target is correct for your setup.

# When frontend and backend are on different origins, set this and rebuild frontend.
# VITE_API_URL=https://sshcontrol.com

# SMPP: if backend runs elsewhere but SMPP whitelists YOUR_SERVER_IP, set a proxy on that server:
# SMPP_PROXY=http://YOUR_SERVER_IP:3128
