# API URL - when set, frontend makes direct requests to this URL (bypasses Vite proxy).
# Leave empty to use the proxy (default: http://localhost:8000).
# Examples:
#   Local: leave empty or http://localhost:8000
#   Remote backend: http://your-server-ip:8000 or https://api.yourdomain.com
# VITE_API_URL=

# Proxy target - used by Vite dev server when proxying /api requests.
# Only applies when VITE_API_URL is not set.
# - Local dev: http://localhost:8000 (default)
# - Docker: http://backend:8000
# PROXY_TARGET=http://localhost:8000
